# ── 1. Dependencies (المكتبات والتبعات) ──
# لا يتم رفعها لأنها تُحمل عن طريق npm install أو yarn
node_modules/
.pnpm-store/
jspm_packages/
.pnp
.pnp.js

# ── 2. Next.js & Build Output (نواتج بناء المشروع) ──
# ملفات ناتجة عن عملية الـ Build ولا حاجة لها في المستودع
.next/
out/
build/
dist/
bin/
obj/
.turbo

# ── 3. Environment Variables (الملفات السرية والأمان) ──
# مرفعش أبداً ملفات الـ .env لأنها تحتوي على بيانات حساسة (Passwords, API Keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local
*.local

# ── 4. TypeScript & Tooling ──
# ملفات تعريف البيئة ومعلومات البناء الخاصة بـ TypeScript
*.tsbuildinfo
next-env.d.ts

# ── 5. Debugging & Logs (سجلات الأخطاء) ──
# ملفات اللوج اللي بتنتج لما يحصل مشكلة في التثبيت أو التشغيل
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 6. OS Files (ملفات أنظمة التشغيل) ──
# ملفات بيولدها الويندوز والماك بشكل تلقائي ولا علاقة لها بالكود
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── 7. IDE & Editor Settings (إعدادات المحرر) ──
# إعداداتك الشخصية في VS Code أو WebStorm
.vscode/
.idea/
*.swp
*.swo
.project
.settings/

# ── 8. Testing (ملفات الاختبار) ──
# تقارير تغطية الاختبارات (Coverage Reports)
/coverage
.nyc_output

# ── 9. Deployment (ملفات الرفع) ──
.vercel